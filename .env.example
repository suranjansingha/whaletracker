# ─── Required ─────────────────────────────────────────────────────────────────
ETH_API_KEY=your_etherscan_api_key_here
INFURA_RPC=https://mainnet.infura.io/v3/YOUR_INFURA_PROJECT_ID

# ─── Identity APIs ─────────────────────────────────────────────────────────────
NEYNAR_API_KEY=your_neynar_api_key_here
OPENSEA_API_KEY=your_opensea_api_key_here

# ─── Enrichment (optional) ────────────────────────────────────────────────────
DEBANK_API_KEY=
CLAY_API_KEY=
CLAY_WEBHOOK_URL=
APOLLO_API_KEY=

# ─── Google Sheets ────────────────────────────────────────────────────────────
GOOGLE_SHEET_ID=your_google_sheet_id_here
# For Railway/cloud: base64-encode your service account JSON and paste here
GOOGLE_SERVICE_ACCOUNT_B64=your_base64_encoded_service_account_json

# ─── Tracker Config ───────────────────────────────────────────────────────────
MIN_ETH_BALANCE=20
POLL_INTERVAL_MS=60000
BLOCK_RANGE=1000

# ─── Target Contracts ─────────────────────────────────────────────────────────
TARGET_CONTRACTS=0xe592427a0aece92de3edee1f18e0157c05861564,0x87870bca3f3fd6335c3f4ce8392d69350b4fa4e2,0xbebc44782c7db0a1a60cb6fe97d0b483032ff1c7,0xc3d688b66703497daa19211eedff47f25384cdc3
