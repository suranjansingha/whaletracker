# ─── Required: At least ONE of these RPC sources ────────────────────────────
ETH_API_KEY=your_etherscan_api_key_here       # https://etherscan.io/myapikey
INFURA_RPC=https://mainnet.infura.io/v3/YOUR_INFURA_PROJECT_ID

# ─── Optional: Identity Resolution ───────────────────────────────────────────
DEBANK_API_KEY=your_debank_openapi_key_here   # https://cloud.debank.com/

# ─── Optional: Enrichment ─────────────────────────────────────────────────
CLAY_API_KEY=
APOLLO_API_KEY=

# ─── Tracker Config ───────────────────────────────────────────────────────────
MIN_ETH_BALANCE=20                            # Minimum ETH balance to qualify
POLL_INTERVAL_MS=30000                        # How often to poll (ms)
BLOCK_RANGE=500                               # Blocks to scan per batch

# ─── Contracts to monitor (comma-separated) ──────────────────────────────────
TARGET_CONTRACTS=0x...,0x...
